generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations.
model deals {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sneaker      String?
  buy_price    Decimal?  @db.Decimal
  market_price Decimal?  @db.Decimal
  profit       Decimal?  @db.Decimal
  roi          Decimal?  @db.Decimal
  source       String?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations.
model scans {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brand      String?
  model      String?
  colorway   String?
  confidence Int?
  created_at DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations.
model waitlist {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email      String    @unique(map: "unique_email")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model Sneaker {
  id          Int                  @id @default(autoincrement())
  brand       String
  model       String
  colorway    String
  sku         String               @unique
  imageUrl    String?
  retailPrice Float?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  listings    MarketplaceListing[]
}

model MarketplaceListing {
  id           Int           @id @default(autoincrement())
  sellerName   String
  sellerId     String?
  size         String
  condition    String
  price        Float
  status       ListingStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sneakerId    Int
  listingHolds ListingHold[]
  sneaker      Sneaker       @relation(fields: [sneakerId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([sneakerId])
}

model ListingHold {
  id              Int                @id @default(autoincrement())
  listingId       Int
  buyerName       String
  buyerId         String?
  expiresAt       DateTime
  status          HoldStatus         @default(ACTIVE)
  createdAt       DateTime           @default(now())
  buyerEmail      String?
  buyerNotes      String?
  shippingAddress String?
  shippingCity    String?
  shippingCountry String?
  shippingRegion  String?
  listing         MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([buyerId])
}

model InventoryItem {
  id            Int      @id @default(autoincrement())
  userId        String?
  name          String
  brand         String?
  model         String?
  colorway      String?
  size          String?
  condition     String?
  source        String?
  status        String   @default("unlisted")
  purchasePrice Float?
  marketPrice   Float?
  listedPrice   Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NewsArticle {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  excerpt      String?
  category     String
  coverImage   String?
  images       Json?
  author       String?
  sourceName   String?
  sourceUrl    String?
  body         String
  marketAngle  String?
  flipScore    Int?
  actionLabel  String?
  actionNote   String?
  isPublished  Boolean  @default(false)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

enum ListingStatus {
  ACTIVE
  SOLD
  DRAFT
  HELD
}

enum HoldStatus {
  ACTIVE
  RELEASED
  COMPLETED
}