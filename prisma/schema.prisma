
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model SneakerScan {
  id            Int      @id @default(autoincrement())
  query         String
  medianPrice   Float
  averagePrice  Float
  lowestPrice   Float
  highestPrice  Float
  volatility    Float
  marketLabel   String
  totalListings Int
  createdAt     DateTime @default(now())
}
